# Resend API Key (get from resend.com)
RESEND_API_KEY=re_123456789

# Alert recipient
ALERT_EMAIL_TO=you@gmail.com

# Google Sheets
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# LOCAL DEV: point at your service-account.json file (avoids dotenv multi-line issues)
GOOGLE_CREDENTIALS_FILE=./service-account.json

# RAILWAY: in the Railway dashboard Variables tab, add this as a single-line JSON string
# (do NOT put it in .env — dotenv cannot parse multi-line JSON)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# State file path
# Local: ./state.json (auto-created on first run)
# Railway: /data/state.json (Railway Volume mount at /data)
STATE_FILE_PATH=./state.json
